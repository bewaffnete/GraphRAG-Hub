# ─── Neo4j Connection ────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DATABASE=neo4j

# ─── Embedding Provider ───────────────────────────────────────────────────────
# Choices: hash | openai | gemini | ollama
EMBEDDING_PROVIDER=ollama

# Default model per provider:
#   hash   → hash-embedding-v1  (no API key needed, for testing)
#   openai → text-embedding-3-large
#   gemini → gemini-embedding-001
#   ollama → embeddinggemma
EMBEDDING_MODEL=qwen3-embedding:0.6b
EMBEDDING_DIMENSIONS=768

# ─── OpenAI (Embeddings Only) ──────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Gemini (Embeddings Only) ──────────────────────────────────────────────────
GEMINI_API_KEY=your_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# Task type used when indexing documents:
GEMINI_TASK_TYPE=RETRIEVAL_DOCUMENT
# Task type used when searching (query):
GEMINI_QUERY_TASK_TYPE=RETRIEVAL_QUERY

# ─── Ollama (LLM and Embeddings) ──────────────────────────────────────────────
# Use http://localhost:11434 if running GraphRAG CLI directly on your machine.
# Use http://host.docker.internal:11434 if running GraphRAG inside Docker but Ollama on host.
# Use http://ollama:11434 if running both GraphRAG and Ollama inside Docker.
OLLAMA_BASE_URL=http://localhost:11434
LLM_PROVIDER=ollama
LLM_MODEL=gemma4:31b-cloud

# ─── Local Virtual Environment Path ──────────────────────────────────────────
# Path to your local venv site-packages folder to allow indexing installed libs
VENV_LIBS_PATH=./.venv/lib/python3.11/site-packages