# ─── Neo4j Connection ────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DATABASE=neo4j

# ─── Embedding Provider ───────────────────────────────────────────────────────
# Choices: hash | openai | gemini | ollama
EMBEDDING_PROVIDER=hash

# Default model per provider:
#   hash   → hash-embedding-v1  (no API key needed, for testing)
#   openai → text-embedding-3-large
#   gemini → gemini-embedding-001
#   ollama → embeddinggemma
EMBEDDING_MODEL=hash-embedding-v1
EMBEDDING_DIMENSIONS=256

# ─── OpenAI / OpenAI-compatible ──────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ─── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# Task type used when indexing documents:
GEMINI_TASK_TYPE=RETRIEVAL_DOCUMENT
# Task type used when searching (query):
GEMINI_QUERY_TASK_TYPE=RETRIEVAL_QUERY

# ─── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LLM_PROVIDER=ollama
LLM_MODEL=gemini4:31b

#   1 LLM_PROVIDER=openai
#   2 LLM_MODEL=gpt-4o
#   3 OPENAI_API_KEY=your_key_here
#
#  Для Claude (Anthropic):
#
#   1 LLM_PROVIDER=anthropic
#   2 LLM_MODEL=claude-3-5-sonnet-20240620
#   3 ANTHROPIC_API_KEY=your_key_here
#
#  Для Gemini:
#
#   1 LLM_PROVIDER=gemini
#   2 LLM_MODEL=gemini-1.5-pro
#   3 GEMINI_API_KEY=your_key_here