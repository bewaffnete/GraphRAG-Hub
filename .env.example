GRAPHRAG_APP_NAME=graphrag-mcp
GRAPHRAG_APP_VERSION=0.1.0

GRAPHRAG_NEO4J_BACKEND=neo4j
GRAPHRAG_NEO4J_URI=bolt://localhost:7687
GRAPHRAG_NEO4J_USERNAME=neo4j
GRAPHRAG_NEO4J_PASSWORD=change-me
GRAPHRAG_NEO4J_DATABASE=neo4j
GRAPHRAG_NEO4J_VECTOR_INDEX_NAME=graph_node_embedding_index
GRAPHRAG_NEO4J_FULLTEXT_INDEX_NAME=graph_node_fulltext_index

GRAPHRAG_EMBEDDING_PROVIDER=ollama
GRAPHRAG_EMBEDDING_API_KEY=change-me
GRAPHRAG_EMBEDDING_MODEL=qwen3-embedding:0.6b
GRAPHRAG_EMBEDDINGS_ENABLED=true
GRAPHRAG_EMBEDDING_BASE_URL=http://localhost:11434/api
GRAPHRAG_EMBEDDING_TIMEOUT_SECONDS=30
GRAPHRAG_EMBEDDING_SCHEMA_VERSION=v1

GRAPHRAG_REGISTRY_BACKEND=in_memory
GRAPHRAG_VENV_LIBS_CONTAINER_PATH=/user_venv
# Host path mounted into the MCP container at /user_venv.
# Point this to your venv site-packages directory, for example:
# /path/to/.venv/lib/python3.13/site-packages
VENV_LIBS_PATH=./.docker/user_venv_empty
GRAPHRAG_LOG_LEVEL=INFO
GRAPHRAG_LOG_FORMAT=human
